# ─────────────────────────────────────────────────────────────
# Motor INSIGHT — variables de entorno
# Copia este fichero a `.env` y rellena los valores reales.
# El `.env` real está en .gitignore: NUNCA se sube al repo.
# ─────────────────────────────────────────────────────────────

# --- Supabase (mismo proyecto que RetailSync) ---
# URL del proyecto, p.ej. https://abcdefgh.supabase.co
SUPABASE_URL=

# SERVICE KEY (no la anon key). Da acceso de lectura/escritura saltándose RLS.
# Es un secreto sensible: trátala como una contraseña de admin.
SUPABASE_SERVICE_KEY=

# --- Anthropic (Claude API) para el motor narrativo ---
# Empieza por "sk-ant-..."
ANTHROPIC_API_KEY=

# --- Opcionales (tienen valor por defecto en src/config.py) ---
# Modelo de Claude para la narrativa
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Tabla de hexágonos en Supabase
# HEXES_TABLE=hexes
# Columna que identifica la ciudad dentro de esa tabla
# CITY_COLUMN=city
# Ruta de la cache local SQLite
# LOCAL_CACHE_PATH=data/insight_cache.db

# --- Señales externas (opcionales) ---
# Ticketmaster Discovery (Consumer Key) — venues/eventos
TM_API_KEY=
# Mobility Database (refresh token) — paradas GTFS como POIs de transporte
# Registro gratuito: https://mobilitydatabase.org
MOBILITY_DB_REFRESH_TOKEN=

# --- API HTTP (despliegue) ---
# Clave exigida en la cabecera X-API-Key de /insight. Vacía = sin auth (solo dev).
# Genera una con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INSIGHT_API_KEY=
# Orígenes CORS permitidos (coma-separados). En producción: dominio del frontend.
# ALLOWED_ORIGINS=https://tuapp.lovable.app
